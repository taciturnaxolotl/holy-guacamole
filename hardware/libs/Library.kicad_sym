		(property "SolderSlack Pin Current Facts" "{\"version\":1,\"source\":\"solderslack.datasheet\",\"productCode\":\"C2909059\",\"productModel\":\"SK9822-EC20\",\"pins\":{\"5\":{\"pinFunction\":\"VDD\",\"facts\":[{\"kind\":\"typical_current_a\",\"currentA\":0.001,\"direction\":\"sink\",\"scope\":\"rail\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Section 10, \\\"The IC electrical parameters\\\" table: static power consumption (IDD) is typically 1 mA.\",\"conditions\":\"Static power consumption, IDD.\"},{\"kind\":\"typical_current_a\",\"currentA\":0.018,\"direction\":\"sink\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"medium\",\"evidence\":\"Section 7 describes the device as the \\\"18MA current version\\\" of the 9822 series; Section 11 \\\"5-Bit brightness adjustment\\\" table gives nominal current for an LED channel at level 32 as 18 mA.\",\"conditions\":\"Per LED channel; brightness level 32.\"},{\"kind\":\"max_operating_current_a\",\"currentA\":0.005229,\"direction\":\"sink\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Section 11, Note 2: based on heat dissipation, the recommended maximum operating current for each LED channel is 5.229 mA.\",\"conditions\":\"Per LED channel; heat-dissipation-based recommended maximum operating current.\"},{\"kind\":\"max_operating_current_a\",\"currentA\":0.02,\"direction\":\"sink\",\"scope\":\"load_path\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Section 10, \\\"The IC electrical parameters\\\" table: maximum individual LED output current (Imax) is 20 mA.\",\"conditions\":\"Per individual LED output/channel.\"}]}},\"notes\":[\"No datasheet current facts were provided for pins 1 SDO, 2 GND, 3 SDI, 4 CKL/CKI, or 6 CKO in the retrieved material.\"]}"
