			(property "SolderSlack Pin Current Facts" "{\"version\":1,\"source\":\"solderslack.datasheet\",\"productCode\":\"C350557\",\"productModel\":\"SN74AHCT1G125\",\"pins\":{\"1\":{\"pinFunction\":\"#OE\",\"facts\":[{\"kind\":\"max_operating_current_a\",\"currentA\":0.000001,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Input leakage current II, max 1 µA for VI = 5.5 V or GND.\",\"conditions\":\"VI = 5.5 V or GND\"},{\"kind\":\"typical_current_a\",\"currentA\":1e-7,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Input leakage current II, typical 0.1 µA at TA = 25°C.\",\"conditions\":\"TA = 25°C\"},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.02,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Input clamp current IIK, 20 mA for VI < 0.\",\"conditions\":\"VI < 0\"}]},\"2\":{\"pinFunction\":\"A\",\"facts\":[{\"kind\":\"max_operating_current_a\",\"currentA\":0.000001,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Input leakage current II, max 1 µA for VI = 5.5 V or GND.\",\"conditions\":\"VI = 5.5 V or GND\"},{\"kind\":\"typical_current_a\",\"currentA\":1e-7,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Input leakage current II, typical 0.1 µA at TA = 25°C.\",\"conditions\":\"TA = 25°C\"},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.02,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Input clamp current IIK, 20 mA for VI < 0.\",\"conditions\":\"VI < 0\"}]},\"3\":{\"pinFunction\":\"GND\",\"facts\":[{\"kind\":\"absolute_max_current_a\",\"currentA\":0.05,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Absolute maximum rating: continuous current through GND, 50 mA.\",\"conditions\":null}]},\"4\":{\"pinFunction\":\"Y\",\"facts\":[{\"kind\":\"max_operating_current_a\",\"currentA\":0.008,\"direction\":\"bidirectional\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Recommended continuous high-level or low-level output current, IOH and IOL, 8 mA at VCC = 4.5 V.\",\"conditions\":\"VCC = 4.5 V\"},{\"kind\":\"max_operating_current_a\",\"currentA\":0.0000025,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"3-state output off-state current IOZ, max 2.5 µA.\",\"conditions\":null},{\"kind\":\"typical_current_a\",\"currentA\":2.5e-7,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"3-state output off-state current IOZ, typical 0.25 µA at TA = 25°C.\",\"conditions\":\"TA = 25°C\"},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.025,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Absolute maximum rating: continuous output current IO, 25 mA.\",\"conditions\":null},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.02,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Output clamp current IOK, 20 mA for VO < 0 or VO > VCC.\",\"conditions\":\"VO < 0 or VO > VCC\"}]},\"5\":{\"pinFunction\":\"VCC\",\"facts\":[{\"kind\":\"max_operating_current_a\",\"currentA\":0.00001,\"direction\":\"sink\",\"scope\":\"rail\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Static supply current ICC, max 10 µA for VI = VCC or GND and IO = 0.\",\"conditions\":\"VI = VCC or GND; IO = 0\"},{\"kind\":\"max_operating_current_a\",\"currentA\":0.0015,\"direction\":\"sink\",\"scope\":\"rail\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Quiescent supply current ΔICC per input, max 1.5 mA for one input at 3.4 V and other inputs at VCC or GND.\",\"conditions\":\"One input at 3.4 V; other inputs at VCC or GND\"},{\"kind\":\"typical_current_a\",\"currentA\":0.000001,\"direction\":\"sink\",\"scope\":\"rail\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Static supply current ICC, typical 1 µA at TA = 25°C.\",\"conditions\":\"TA = 25°C\"},{\"kind\":\"typical_current_a\",\"currentA\":0.00135,\"direction\":\"sink\",\"scope\":\"rail\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Quiescent supply current ΔICC per input, typical 1.35 mA at TA = 25°C.\",\"conditions\":\"TA = 25°C\"},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.05,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Absolute maximum rating: continuous current through VCC, 50 mA.\",\"conditions\":null}]}}}"
