			(property "SolderSlack Pin Current Facts" "{\"version\":1,\"source\":\"solderslack.datasheet\",\"productCode\":\"C122228\",\"productModel\":\"INA180\",\"pins\":{\"1\":{\"pinFunction\":\"OUT\",\"facts\":[{\"kind\":\"absolute_max_current_a\",\"currentA\":0.008,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Section 7.1 Absolute Maximum Ratings lists \\\"Maximum output current, IOUT\\\" as 8 mA.\",\"conditions\":null},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.005,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"medium\",\"evidence\":\"Section 7.1 Absolute Maximum Ratings note states that voltage at any pin can exceed the shown voltage if the current at that pin is limited to 5 mA.\",\"conditions\":\"Applies when voltage at the pin exceeds the shown absolute maximum voltage limit.\"}]},\"3\":{\"pinFunction\":\"IN+\",\"facts\":[{\"kind\":\"typical_current_a\",\"currentA\":0.000055,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Section 8.4.3 Shutdown Mode describes an \\\"additional and well-matched 55-µA typical current that flows in each of the inputs.\\\"\",\"conditions\":\"Shutdown mode.\"},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.005,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"medium\",\"evidence\":\"Section 7.1 Absolute Maximum Ratings note states that voltage at any pin can exceed the shown voltage if the current at that pin is limited to 5 mA.\",\"conditions\":\"Applies when voltage at the pin exceeds the shown absolute maximum voltage limit.\"}]},\"4\":{\"pinFunction\":\"IN-\",\"facts\":[{\"kind\":\"typical_current_a\",\"currentA\":0.000055,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Section 8.4.3 Shutdown Mode describes an \\\"additional and well-matched 55-µA typical current that flows in each of the inputs.\\\"\",\"conditions\":\"Shutdown mode.\"},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.005,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"medium\",\"evidence\":\"Section 7.1 Absolute Maximum Ratings note states that voltage at any pin can exceed the shown voltage if the current at that pin is limited to 5 mA.\",\"conditions\":\"Applies when voltage at the pin exceeds the shown absolute maximum voltage limit.\"}]},\"5\":{\"pinFunction\":\"VS\",\"facts\":[{\"kind\":\"max_operating_current_a\",\"currentA\":0.00026,\"direction\":\"sink\",\"scope\":\"rail\",\"basis\":\"datasheet\",\"confidence\":\"high\",\"evidence\":\"Section 3 Description states: \\\"The single-channel INA180 draws a maximum supply current of 260 µA.\\\"\",\"conditions\":null},{\"kind\":\"absolute_max_current_a\",\"currentA\":0.005,\"direction\":\"unknown\",\"scope\":\"pin\",\"basis\":\"datasheet\",\"confidence\":\"medium\",\"evidence\":\"Section 7.1 Absolute Maximum Ratings note states that voltage at any pin can exceed the shown voltage if the current at that pin is limited to 5 mA.\",\"conditions\":\"Applies when voltage at the pin exceeds the shown absolute maximum voltage limit.\"}]}},\"notes\":[\"No directly supported current fact was provided for pin 2 (GND); the 260-µA supply current was reported as supply current, not an explicit GND-pin current.\"]}"
				(at 0 0 0)
